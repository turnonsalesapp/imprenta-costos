# ─────────────────────────────────────────────────────────────────────
#  BASE DE DATOS  —  PostgreSQL en Railway
# ─────────────────────────────────────────────────────────────────────
#
#  Railway te da DOS cadenas distintas. Usa la correcta en cada lugar:
#
#  AQUÍ, en tu computadora  ->  DATABASE_PUBLIC_URL   (dice "rlwy.net")
#  En Railway, variables de la app  ->  ${{Postgres.DATABASE_URL}}
#
#  Si copias la interna (dice "railway.internal") en este archivo, vas a
#  recibir "Can't reach database server" al correr las migraciones.
#
DATABASE_URL="postgresql://postgres:CLAVE@shortline.proxy.rlwy.net:12345/railway"

# ─────────────────────────────────────────────────────────────────────
#  SESIONES
# ─────────────────────────────────────────────────────────────────────
#  Genérala con:
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#  Usa el MISMO valor aquí y en las variables de Railway.
AUTH_SECRET="cambiar-por-una-clave-larga-y-aleatoria"

# ─────────────────────────────────────────────────────────────────────
#  PRIMER ADMINISTRADOR  (lo crea `npm run db:seed`)
# ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@imprenta.com"
ADMIN_PASSWORD="cambiar123"

# ─────────────────────────────────────────────────────────────────────
#  INTERPRETAR SOLICITUD CON IA  (opcional)
# ─────────────────────────────────────────────────────────────────────
#  Habilita el panel "Interpretar solicitud del cliente" en Cotizar. Sin esta
#  clave la función queda oculta. Configúrala como SECRETO del entorno en
#  Railway, nunca en el repositorio. El texto pegado se envía a la API de
#  Anthropic para procesarlo.
#  El modelo se elige en Variables (Opus 4.8 / Sonnet 5 / Haiku 4.5).
#  ANTHROPIC_MODEL solo se usa como respaldo si no se eligió ninguno.
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-8"
